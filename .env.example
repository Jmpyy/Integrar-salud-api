# ============================================================
# Integrar Salud — Backend Environment Variables
# Copiar como .env y completar con valores reales
# NUNCA commitear el .env real al repositorio
# ============================================================

# Base de datos (datos que configuramos en MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tu_dbnombre_aqui
DB_USER=tu_user_aqui
DB_PASS=tu_password_aqui

# Seguridad (JWT)
# Genera una clave larga y única (puedes escribir lo que quieras aquí)
JWT_SECRET=tu_jwt_secret_aqui

# Configuración de App
APP_ENV=development

# CORS: Permite peticiones desde la web oficial y desde el entorno de desarrollo local
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Límites de seguridad
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Rate Limiter — Proxy Trust
# false = usar REMOTE_ADDR directamente (correcto para VPS con Nginx sin proxy/CDN externo)
# true = solo si hay Cloudflare o un load balancer externo frente al servidor
TRUST_PROXY=false
