# ============================================================
# Integrar Salud — Backend Environment Variables
# Copiar como .env y completar con valores reales
# NUNCA commitear el .env real al repositorio
# ============================================================

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=integrar_salud
DB_USER=root
DB_PASS=

# JWT — Generar con: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=GENERATE_A_STRONG_RANDOM_SECRET_HERE

# Application
APP_ENV=production
# Valores: development | production
# En production: deshabilita debug_log, aplica CORS estricto

# CORS — Orígenes permitidos separados por coma
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# Rate Limiting (intentos de login)
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
